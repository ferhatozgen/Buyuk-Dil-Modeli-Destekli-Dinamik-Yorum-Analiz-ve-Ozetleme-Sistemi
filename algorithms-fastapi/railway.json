{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "nixpacksPlan": {
      "providers": ["python"],
      "phases": {
        "build": {
          "cmds": [
            "pip install -r requirements.txt"
          ]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "uvicorn api_runner:app --host 0.0.0.0 --port $PORT"
  }
}
