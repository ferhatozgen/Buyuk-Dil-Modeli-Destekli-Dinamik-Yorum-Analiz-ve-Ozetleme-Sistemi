{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "nixpacksPlan": {
      "providers": ["python"],
      "phases": {
        "setup": {
          "aptPkgs": ["xvfb"]
        },
        "build": {
          "cmds": [
            "pip install -r requirements.txt",
            "playwright install --with-deps chromium"
          ]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "tail -f /dev/null"
  }
}